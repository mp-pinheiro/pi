{
  "network": {
    "allowedDomains": ["openrouter.ai", "*.openrouter.ai", "api.search.brave.com", "api.z.ai", "chatgpt.com", "api.exa.ai"],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead":  ["~"],
    "allowRead":  [".", "~/.pi/agent", "~/.local/share/fnm", "~/.npmrc"],
    "allowWrite": [".", "~/.pi/sessions", "~/.pi/memory", "~/.pi/agent", "/tmp"],
    "denyWrite":  []
  },
  "seccomp": {
    "applyPath": "/usr/local/bin/apply-seccomp"
  }
}
